        part_title = part['title']
        active_class = ' class="active"' if i == is_active else ''
        sidebar_links += f'           <a href="part-{i:02d}.html"{active_class}>{i}. {part_title}</a>\n'
    
    template = f'''<!DOCTYPE html>
<html lang="en">
<head>
