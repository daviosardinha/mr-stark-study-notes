      max-width: 100%; 
      height: auto; 
      margin: 20px 0; 
      border-radius: 8px; 
      box-shadow: 0 4px 8px rgba(0,0,0,0.3);
    }}
    .notion-content h1 {{ 
      font-size: 1.8rem; 
      margin: 30px 0 20px; 
      color: #fafafa; 
    }}
    .notion-content h2 {{ 
      font-size: 1.5rem; 
      margin: 25px 0 15px; 
      color: #fafafa; 
    }}
    .notion-content h3 {{ 
      font-size: 1.3rem; 
      margin: 20px 0 10px; 
      color: #fafafa; 
    }}
    .notion-content p {{ 
      margin: 15px 0; 
      color: #d6d6d6; 
    }}
    .notion-content ul, .notion-content ol {{ 
      margin: 15px 0; 
      padding-left: 30px; 
    }}
    .notion-content li {{ 
      margin: 5px 0; 
