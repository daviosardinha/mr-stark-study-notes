      font-size: 0.9rem; 
      font-weight: 600;
      background: #2a2a2a;
      transition: all 0.2s;
    }}
    .project-sidebar .portfolio-link:hover {{ 
      background: #ffdb70; 
      color: #1a1a1a; 
    }}
    .project-sidebar a {{ 
      display: block; 
      padding: 8px 12px; 
      margin: 4px 0; 
      color: #d6d6d6; 
      text-decoration: none; 
      border-radius: 6px; 
      font-size: 0.9rem; 
      transition: all 0.2s; 
    }}
    .project-sidebar a:hover {{ 
      background: #2a2a2a; 
      color: #ffdb70; 
    }}
    .project-sidebar a.active {{ 
      background: #ffdb70; 
      color: #1a1a1a; 
      font-weight: 600; 
    }}
    
    .notion-content {{ 
      line-height: 1.6; 
    }}
