#!/usr/bin/env python3
"""
CRTP Migration Script
Groups Notion export content into logical parts and applies vCard template
"""

import os
import re
from pathlib import Path
from bs4 import BeautifulSoup

def extract_sections_from_notion_export(html_file):
    """Extract content sections based on h1 headings from Notion export"""
    with open(html_file, 'r', encoding='utf-8') as f:
        content = f.read()
    
    # Parse the HTML
    soup = BeautifulSoup(content, 'html.parser')
    
    # Find all h1 elements (these are our section boundaries)
    h1_elements = soup.find_all('h1')
    
    sections = []
    for i, h1 in enumerate(h1_elements):
        # Get the title
        title = h1.get_text(strip=True)
        
        # Get content until next h1 or end of document
        content_parts = []
        current = h1.next_sibling
        
        while current and (not hasattr(current, 'name') or current.name != 'h1'):
            if hasattr(current, 'get_text'):
                text = current.get_text()
                if text.strip():
                    content_parts.append(str(current))
            current = current.next_sibling
        
        section_content = ''.join(content_parts)
        sections.append({
            'title': title,
            'content': f'<h1>{title}</h1>{section_content}',
            'index': i + 1
        })
    
    return sections

def clean_notion_artifacts(html_content):
    """Remove Notion-specific HTML artifacts"""
    # Remove <mark> tags but keep content
    html_content = re.sub(r'<mark[^>]*>', '', html_content)
    html_content = html_content.replace('</mark>', '')
    
    # Remove <details> and <summary> wrappers
    html_content = re.sub(r'</?details[^>]*>', '', html_content)
    html_content = re.sub(r'</?summary>', '', html_content)
    
    # Convert toggle lists to bulleted lists
    html_content = html_content.replace('class="toggle"', 'class="bulleted-list"')
    
    # Remove inline styles from code blocks
    html_content = re.sub(r'\s*style="white-space:pre-wrap;word-break:break-all"', '', html_content)
    
    # Remove other inline styles from code elements
    html_content = re.sub(r'<code class="([^"]+)" style="[^"]*">', r'<code class="\1">', html_content)
    
    # Convert blockquotes to emphasized paragraphs
    def convert_blockquote(match):
        content = match.group(1)
        return f'<p class="note"><em>{content}</em></p>'
    
    html_content = re.sub(r'<blockquote[^>]*>(.*?)</blockquote>', convert_blockquote, html_content, flags=re.DOTALL)
    
    # Remove empty paragraphs
    html_content = re.sub(r'<p[^>]*>\s*</p>', '', html_content)
    
    # Remove placeholder content
    placeholder_patterns = [
        r'<h[123][^>]*>Future Attack[^<]*</h[123]>',
        r'<p[^>]*>[^<]*Future Attack[^<]*</p>',
        r'<p[^>]*>[^<]*TODO:[^<]*</p>',
        r'<p[^>]*>[^<]*PLACEHOLDER[^<]*</p>',
    ]
    for pattern in placeholder_patterns:
        html_content = re.sub(pattern, '', html_content, flags=re.IGNORECASE)
    
    return html_content

def fix_image_paths(html_content):
    """Fix Notion's invalid anchor attributes for images"""
    # Fix <a src=" to <a href="
    html_content = html_content.replace('<a src="', '<a href="')
    
    # Remove data URLs or invalid image sources
    html_content = re.sub(r'<img[^>]*src="data:[^"]*"[^>]*>', '<!-- Image removed: data URL not supported -->', html_content)
    
    # Ensure image paths are relative
    html_content = re.sub(r'src="/images/', 'src="images/', html_content)
    
    return html_content

def fix_code_languages(html_content):
    """Fix incorrect language classes in code blocks"""
    # Simple fix: change language-JavaScript to language-bash for terminal output
    html_content = re.sub(r'language-JavaScript', 'language-bash', html_content)
    html_content = re.sub(r'language-Bash', 'language-bash', html_content)
    
    # For terminal output that should be plain text
    html_content = re.sub(r'language-javascript', 'language-text', html_content, flags=re.IGNORECASE)
    
    return html_content

def apply_vcard_template(title, content, is_active=False, all_parts=None):
