    <div class="main-content">
      <article class="about active" data-page="about">
        <div class="overview-content">
          <h1>CRTP - Certified Red Team Professional</h1>
          <p>A comprehensive walkthrough of the CRTP certification labs and exercises.</p>
          <h3 style="color: #ffdb70; margin: 30px 0 20px;">Course Sections</h3>
          <ul>
{parts_html}          </ul>
        </div>
      </article>
    </div>

    <script src="../assets/js/script.js"></script>
    <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
    <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>
  </body>
</html>'''
    return template

def create_index_redirect():
    """Create index.html that redirects to overview"""
    return '''<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content="0; url=overview.html">
  <title>CRTP - Certified Red Team Professional</title>
</head>
<body>
  <p>Redirecting to <a href="overview.html">overview</a>...</p>
</body>
</html>'''

def main():
    """Main migration function"""
    print("Starting CRTP migration...")
    
    # Paths
    export_dir = Path("/home/stark/Downloads/crtp-export-new/crtp-final")
    notion_html = export_dir / "CRTP - Certified Red Team Professional 30c79e9ad7c9801b9285cbdbfdd8d9e4.html"
    output_dir = Path("/home/stark/mr-stark-study-notes/crtp")
    images_dir = output_dir / "images"
    
    # Ensure output directory exists
    output_dir.mkdir(exist_ok=True)
    images_dir.mkdir(exist_ok=True)
    
    # Extract sections from Notion export
    print("Extracting sections from Notion export...")
    sections = extract_sections_from_notion_export(notion_html)
    print(f"Found {len(sections)} sections")
    
    # Define logical groupings (15 parts as planned)
    groupings = [
        # Part 1: PowerShell Detection & Bypass
        {
            'title': 'PowerShell Detection & Bypass',
            'indices': [1, 2, 3, 4, 5, 6, 7]  # PowerShell Detections through PowerShell Detection Bypass
        },
        # Part 2: Enumeration Tools
        {
            'title': 'Enumeration Tools',
            'indices': [2, 3, 4, 5, 8]  # AD Module, BloodHound, PowerView(PowerShell), SharpView, ADModule
        },
        # Part 3: Domain Enumeration Techniques
        {
            'title': 'Domain Enumeration Techniques',
            'indices': [6, 15, 18, 24, 25, 26]  # Various enumeration sections
        },
        # Part 4: Privilege Escalation (Derivative Local Admin)
        {
            'title': 'Privilege Escalation (Derivative Local Admin)',
            'indices': [9]  # Derivative Local Admin Abuse
        },
        # Part 5: Golden Ticket
        {
            'title': 'Golden Ticket',
            'indices': [10, 11, 12]  # Golden Ticket (Rubeus, BetterSafetyKatz, PowerShell Remoting)
        },
        # Part 6: Silver Ticket & WMI Abuse
        {
            'title': 'Silver Ticket & WMI Abuse',
            'indices': [13, 14]  # Silver Ticket, BetterSafetyKatz for WMI
        },
        # Part 7: Diamond Ticket
        {
            'title': 'Diamond Ticket',
            'indices': [15]  # Diamond Ticket With Rubeus
        },
        # Part 8: DCSync Attack
        {
            'title': 'DCSync Attack',
            'indices': [16]  # Enumeration (DCSync section)
        },
        # Part 9: AS-REP Roasting
        {
            'title': 'AS-REP Roasting',
            'indices': [17, 18]  # Both AS-REP variants
        },
        # Part 10: Unconstrained Delegation + Printer Bug
        {
            'title': 'Unconstrained Delegation + Printer Bug',
            'indices': [19, 20]  # Unconstrained Delegation, Printer Bug
        },
        # Part 11: Constrained Delegation
        {
            'title': 'Constrained Delegation',
            'indices': [21, 22]  # User + Computer accounts
        },
        # Part 12: Resource-Based Constrained Delegation (RBCD)
        {
            'title': 'Resource-Based Constrained Delegation (RBCD)',
            'indices': [23]  # Enumerating RBCD
        },
        # Part 13: Trust Enumeration & Abuse
        {
            'title': 'Trust Enumeration & Abuse',
            'indices': [24, 25]  # Trust enumeration sections
        },
        # Part 14: Cross-Forest Trust Attacks
        {
            'title': 'Cross-Forest Trust Attacks',
            'indices': [26]  # ADCS section (we'll use this for trust attacks)
        },
        # Part 15: ADCS Attacks (ESC1, ESC3)
        {
            'title': 'ADCS Attacks (ESC1, ESC3)',
            'indices': [27, 28]  # ESC1, ESC3
        },
        # Part 16: Tools Transfer & Execution
        {
            'title': 'Tools Transfer & Execution',
            'indices': [29]  # Tools Transfer and Execution
        },
        # Part 17: ASR Rules Bypass (Lateral Movement)
        {
            'title': 'ASR Rules Bypass (Lateral Movement)',
            'indices': [30]  # Lateral Movement – ASR Rules Bypass
        }
    ]
    
    # Process each group
    print("Processing content groups...")
    all_parts = []
    
    for group_idx, group in enumerate(groupings, 1):
        print(f"  Processing Part {group_idx:02d}: {group['title']}")
        
        # Collect content for this group
        group_content = []
        for idx in group['indices']:
            if idx <= len(sections):
                section = sections[idx - 1]  # Adjust for 0-based indexing
                # Clean the content
                cleaned = clean_notion_artifacts(section['content'])
                cleaned = fix_image_paths(cleaned)
                cleaned = fix_code_languages(cleaned)
                group_content.append(cleaned)
        
        # Combine content
        combined_content = '\n'.join(group_content)
        
        # Apply vCard template
        html_content = apply_vcard_template(
            title=group['title'],
            content=combined_content,
            is_active=False,  # Will be set correctly in template generation
            all_parts=[g['title'] for g in groupings]
        )
        
        # Save part file
        part_filename = output_dir / f"part-{group_idx:02d}.html"
        with open(part_filename, 'w', encoding='utf-8') as f:
            f.write(html_content)
        
        all_parts.append({
            'title': group['title'],
            'filename': f"part-{group_idx:02d}.html"
        })
        
        print(f"    Saved: {part_filename}")
    
    # Generate overview.html
    print("Generating overview.html...")
    overview_content = create_overview_page(all_parts)
    overview_file = output_dir / "overview.html"
    with open(overview_file, 'w', encoding='utf-8') as f:
        f.write(overview_content)
    print(f"  Saved: {overview_file}")
    
    # Generate index.html
    print("Generating index.html...")
    index_content = create_index_redirect()
    index_file = output_dir / "index.html"
    with open(index_file, 'w', encoding='utf-8') as f:
        f.write(index_content)
    print(f"  Saved: {index_file}")
    
    print("\nMigration completed successfully!")
    print(f"Generated {len(all_parts)} parts in {output_dir}")
    print(f"Images directory: {images_dir} ({len(list(images_dir.glob('*')))} images)")

if __name__ == "__main__":
    main()